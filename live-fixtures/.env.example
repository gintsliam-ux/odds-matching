# Odds-library Supabase project — the one whose `live_fixtures` table holds the
# OpticOdds-scraped feed. Both vars are required; the app reads this table only.
VITE_SUPABASE_URL=https://your-odds-library-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mongo target for Mapping. SERVER-SIDE ONLY — never read by Vite client code.
# Used by scripts/build-mapping.mjs to populate competition_mapping / event_mapping.
MONGO_URI=mongodb+srv://user:pass@cluster.example.mongodb.net
MONGO_DB=gutsy
MONGO_COLL=events
